# ============================================================
# Pavo AI Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# For Railway deployment, set these via Railway dashboard.

# — Agnes AI (required) —
AGNES_API_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_API_KEY=your_api_key_here

# — Railway auto-configures these; override if needed —
# PORT is set automatically by Railway.  Don't set it manually.
# CORS_ORIGINS defaults to http://localhost:3000 in dev.
#   Set to your Railway frontend domain, e.g.:
#   CORS_ORIGINS=https://pavo-frontend.railway.app
#
# PAVO_PUBLIC_URL sets the public base for static file URLs.
#   Defaults to http://localhost:{PORT} in dev.
#   Set to your Railway backend domain, e.g.:
#   PAVO_PUBLIC_URL=https://pavo-backend.railway.app

# — Frontend (if deployed separately) —
# NEXT_PUBLIC_API_BASE=https://pavo-backend.railway.app/api

# — Logging —
LOG_LEVEL=INFO

# — Optional overrides —
# PAVO_HOME=/data/.pavo      # For Railway Volume persistence
# MAX_CONCURRENT_VIDEO_JOBS=3
# VIDEO_TIMEOUT_SECONDS=300
